# Copy to /etc/loglens/env on the VM (chmod 600).
# Also copy POSTGRES_PASSWORD into deploy/.env for docker compose.

# --- Postgres (docker compose) ---
POSTGRES_PASSWORD=replace-with-long-random-password

# --- App (systemd reads /etc/loglens/env) ---
PORT=8080
INGESTOR_PORT=8081

DATABASE_URL=postgres://loglens:replace-with-long-random-password@127.0.0.1:5432/loglens?sslmode=disable
REDIS_ADDR=127.0.0.1:6379

JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRY_HOURS=1
REFRESH_TOKEN_EXPIRY_DAYS=7

KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC_LOGS=loglens.logs
KAFKA_CONSUMER_GROUP=loglens-consumer

LOG_RETENTION_HOURS=6
LOG_RETENTION_INTERVAL_MINUTES=15

API_KEY_CACHE_TTL_SECONDS=300
API_KEY_VALIDATION_CACHE_TTL_SECONDS=120

# Public ingestor URL (used by Go SDK clients)
INGESTOR_URL=https://ingest.madhavmaheshwaricreations.in
